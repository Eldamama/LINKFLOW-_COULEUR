<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>LINK FLOW · Victoire virale</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: system-ui, 'Segoe UI', 'Inter', sans-serif;
            background: radial-gradient(circle at 10% 20%, #0b1120, #030614);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 1.5rem;
        }

        .card {
            max-width: 720px;
            width: 100%;
            background: rgba(15, 23, 42, 0.85);
            backdrop-filter: blur(12px);
            border-radius: 2rem;
            padding: 2rem;
            box-shadow: 0 20px 35px -12px rgba(0,0,0,0.5), 0 0 0 1px rgba(71, 85, 125, 0.4);
        }

        .logo {
            font-size: 2.2rem;
            font-weight: 800;
            background: linear-gradient(135deg, #fff, #a5b4fc);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
            text-align: center;
        }

        .badge {
            text-align: center;
            background: #1e293b;
            color: #b9c7ff;
            display: inline-block;
            width: auto;
            margin: 0.5rem auto 1.2rem;
            padding: 0.3rem 1.2rem;
            border-radius: 40px;
            font-size: 0.75rem;
        }

        h2 {
            font-size: 1.6rem;
            font-weight: 600;
            color: #f1f5f9;
            text-align: center;
            margin-bottom: 0.3rem;
        }

        .sub {
            text-align: center;
            color: #9aa9ca;
            margin-bottom: 1.5rem;
            font-size: 0.9rem;
        }

        .form-group {
            margin-bottom: 1rem;
        }

        label {
            color: #cbd5e1;
            font-size: 0.85rem;
            font-weight: 500;
            display: block;
            margin-bottom: 0.3rem;
        }

        input {
            width: 100%;
            padding: 0.8rem 1rem;
            background: #0f1425;
            border: 1px solid #2a3655;
            border-radius: 1rem;
            color: white;
            font-size: 1rem;
        }

        input:focus {
            outline: none;
            border-color: #f97316;
        }

        .btn-primary {
            background: linear-gradient(95deg, #f97316, #ea580c);
            width: 100%;
            padding: 0.9rem;
            border: none;
            border-radius: 2rem;
            font-weight: bold;
            font-size: 1rem;
            color: white;
            cursor: pointer;
            margin-top: 0.8rem;
            transition: 0.2s;
        }

        .btn-primary:hover {
            transform: scale(1.01);
            background: #ea580c;
        }

        /* Bloc viral (après formulaire) */
        .viral-block {
            display: none;
            animation: fadeIn 0.4s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(15px);}
            to { opacity: 1; transform: translateY(0);}
        }

        .viral-card {
            background: #0a0f1e;
            border-radius: 1.5rem;
            padding: 1.5rem;
            border: 1px solid #f9731650;
            margin: 1rem 0;
        }

        .viral-title {
            font-size: 1.4rem;
            font-weight: 700;
            color: #ffb347;
            margin-bottom: 0.5rem;
        }

        .stats {
            background: #00000040;
            padding: 0.8rem;
            border-radius: 1rem;
            margin: 1rem 0;
            display: flex;
            justify-content: space-between;
            gap: 0.5rem;
            flex-wrap: wrap;
        }

        .stat-item {
            text-align: center;
            font-size: 0.75rem;
            color: #b9c7ff;
        }

        .stat-number {
            font-size: 1.6rem;
            font-weight: 800;
            color: #facc15;
        }

        .btn-youtube {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            background: #ff0000;
            color: white;
            font-weight: bold;
            padding: 0.8rem;
            border-radius: 3rem;
            text-decoration: none;
            margin: 1rem 0;
            transition: 0.2s;
        }

        .btn-youtube:hover {
            background: #cc0000;
        }

        .victory-area {
            background: #0b1122;
            border-radius: 1.2rem;
            padding: 1rem;
            text-align: center;
            margin-top: 1rem;
            border: 1px solid #2d3a66;
        }

        .victory-link {
            background: #1e293b;
            padding: 0.8rem;
            border-radius: 1rem;
            font-family: monospace;
            word-break: break-all;
            color: #7dd3fc;
            margin: 0.8rem 0;
        }

        .btn-victory {
            background: #10b981;
            color: white;
            border: none;
            padding: 0.7rem 1rem;
            border-radius: 2rem;
            font-weight: bold;
            cursor: pointer;
            margin-top: 0.5rem;
            width: 100%;
        }

        .btn-victory:disabled {
            background: #4b5563;
            cursor: not-allowed;
        }

        .footnote {
            font-size: 0.7rem;
            color: #6a789b;
            text-align: center;
            margin-top: 1rem;
        }

        .hidden {
            display: none;
        }
    </style>
</head>
<body>
<div class="card">
    <div class="logo">⚡ LINK FLOW</div>
    <div style="text-align: center;"><span class="badge">🔥 ÉTAPE 1 · ACTIVEZ LE CERCLE VIRAL</span></div>

    <!-- Formulaire initial -->
    <div id="stepForm">
        <h2>Devenez l'étincelle 🧨</h2>
        <div class="sub">Votre action sur YouTube = vagues d'adhérents</div>
        <form id="leadForm">
            <div class="form-group">
                <label>👤 Prénom / pseudo</label>
                <input type="text" id="name" placeholder="Alex" required>
            </div>
            <div class="form-group">
                <label>📧 Email (votre accès victory)</label>
                <input type="email" id="email" placeholder="alex@exemple.com" required>
            </div>
            <button type="submit" class="btn-primary">🚀 Je propulse la vidéo</button>
        </form>
        <div class="footnote">Aucun spam — juste votre impact collectif.</div>
    </div>

    <!-- Bloc viral + YouTube + lien Victory (caché initialement) -->
    <div id="stepViral" class="viral-block">
        <div class="viral-card">
            <div class="viral-title">🎯 Vous tenez le levier viral</div>
            <p style="color:#cddcff;">En <strong>likant, commentant et partageant</strong> la vidéo sur YouTube, l'algorithme l'explose. Un effet boule de neige = <strong>des centaines de nouveaux adhérents</strong>.</p>
            <div class="stats">
                <div class="stat-item">📈 Portée x24<br><span class="stat-number">+2 400%</span></div>
                <div class="stat-item">🤝 Adhérents générés<br><span class="stat-number">1 250+</span></div>
                <div class="stat-item">⚡ Shares viraux<br><span class="stat-number">800+</span></div>
            </div>
            
            <!-- Lien YouTube (s'ouvre dans un nouvel onglet) -->
            <a href="https://www.youtube.com/watch?v=9uPybhkqYw4" class="btn-youtube" target="_blank" rel="noopener noreferrer">
                🎬 Regarder & interagir sur YouTube ↗️
            </a>
            
            <!-- Zone de validation manuelle : l'utilisateur revient et confirme -->
            <div class="victory-area">
                <p style="font-weight: 500; margin-bottom: 8px;">✅ Après avoir liké/commenté sur YouTube :</p>
                <button id="unlockVictoryBtn" class="btn-victory">🔓 J'ai interagi, débloquez mon lien Victory</button>
                <div id="victoryContainer" style="margin-top: 1rem;"></div>
            </div>
            <div class="footnote">
                💡 Votre lien Victory automatique = accès au système LINK FLOW + adhésion virale garantie.
            </div>
        </div>
    </div>
</div>

<script>
    const form = document.getElementById('leadForm');
    const stepFormDiv = document.getElementById('stepForm');
    const stepViralDiv = document.getElementById('stepViral');
    const unlockBtn = document.getElementById('unlockVictoryBtn');
    const victoryContainer = document.getElementById('victoryContainer');
    
    let userEmail = '';   // stocker pour personnalisation (optionnel)

    // Étape 1 : soumission formulaire
    form.addEventListener('submit', function(e) {
        e.preventDefault();
        const name = document.getElementById('name').value.trim();
        const email = document.getElementById('email').value.trim();
        if (!name || !email) {
            alert("Merci de remplir les deux champs pour activer la viralité !");
            return;
        }
        userEmail = email;
        // Sauvegarde symbolique (pourrait être envoyée à un webhook)
        localStorage.setItem('leadFlow', JSON.stringify({ name, email, timestamp: Date.now() }));
        
        // Transition : cacher formulaire, afficher bloc viral
        stepFormDiv.style.display = 'none';
        stepViralDiv.style.display = 'block';
        stepViralDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
        
        // Message console
        console.log(`🔥 Lead enregistré: ${name} (${email}) - Prêt pour le déclic YouTube`);
    });
    
    // Étape 2 : déblocage du lien Victory après interaction YouTube (manuel, l'utilisateur revient cliquer)
    unlockBtn.addEventListener('click', function() {
        // Désactiver le bouton pour éviter les doubles clics abusifs
        unlockBtn.disabled = true;
        unlockBtn.textContent = "⏳ GÉNÉRATION DU LIEN VICTORY...";
        
        // Simuler un délai (ou appel API) pour l'effet "automatique"
        setTimeout(() => {
            // Générer un lien Victory unique (ici un lien symbolique, tu peux le personnaliser)
            // Il peut s'agir d'un lien d'accès à ton système, d'un code promo, ou d'une page privée.
            const victoryCode = `VICTORY-${Math.random().toString(36).substr(2, 8).toUpperCase()}`;
            const victoryLink = `https://ton-système.com/victory?code=${victoryCode}&email=${encodeURIComponent(userEmail)}`;
            
            // Afficher le lien dans la zone prévue
            victoryContainer.innerHTML = `
                <div style="background:#0f172a; border-radius:1rem; padding:0.8rem;">
                    <p style="color:#a7f3d0; font-weight:bold;">🏆 VOTRE LIEN VICTORY AUTOMATIQUE 🏆</p>
                    <div class="victory-link">
                        <a href="${victoryLink}" target="_blank" style="color:#5ee0fa; text-decoration:underline;">${victoryLink}</a>
                    </div>
                    <p style="font-size:0.75rem; color:#9ca3af;">Cliquez pour accéder à votre système LINK FLOW + bonus adhérents.</p>
                    <p style="font-size:0.7rem; margin-top:8px;">✅ Victoire enregistrée — partagez ce lien pour amplifier l'effet viral.</p>
                </div>
            `;
            unlockBtn.style.display = 'none';  // cacher le bouton après délivrance
        }, 800);
    });
    
    // Petit message pour éviter l'erreur "No video with supported format"
    console.log("✅ LINK FLOW prêt — aucun lecteur vidéo natif, l'utilisateur garde le contrôle.");
</script>
</body>
</html>
